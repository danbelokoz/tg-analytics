# Локально для parser/ (в CI это GitHub Secrets — НЕ коммить реальные значения)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # service role, только сервер (обходит RLS)

# Опционально для скрейперов:
SEED_FILE=parser/analytics_seed.txt      # засидить каналы из файла
CONCURRENCY=8                            # одновременных запросов к t.me
REQ_DELAY=0.15                           # пауза после запроса, сек

# Для фронта (index.html / jobs.html) — публичные, можно встраивать:
# SUPABASE_ANON_KEY=eyJ...
