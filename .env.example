# Локально для parser/ (в CI это GitHub Secrets, НЕ коммить реальные значения)
TG_API_ID=12345
TG_API_HASH=0123456789abcdef0123456789abcdef
TG_SESSION=          # вывод parser/gen_session.py
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # service role, server-only
CHANNELS=durov,telegram                  # засидить при первом запуске
POSTS_LIMIT=30

# Для фронта (index.html) — публичные, можно встраивать:
# SUPABASE_ANON_KEY=eyJ...
